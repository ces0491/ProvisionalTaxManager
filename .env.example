FLASK_SECRET_KEY=your-secret-key-here
DATABASE_URL=sqlite:///tax_data.db
# For production on Render, use: postgresql://user:password@host:port/database
AUTH_PASSWORD=your-password-here

# Optional: set to true in production (HTTPS) to mark the session cookie Secure.
# Leave unset for local HTTP development so login works.
# SESSION_COOKIE_SECURE=true

# Optional: set to true to enable the Flask debugger when running locally.
# FLASK_DEBUG=true
